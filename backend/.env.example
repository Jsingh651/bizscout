# ─── Core ─────────────────────────────────────────────────────────────────────
# Postgres connection string (Supabase: Project → Settings → Database → URI).
# For local dev you can use SQLite, e.g. sqlite:///./bizscout.db
DATABASE_URL=postgresql://postgres:password@db.<project>.supabase.co:5432/postgres

# Secret used to sign JWTs. Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Salt for hashids (opaque lead/contract IDs in URLs). Use any random string.
HASHIDS_SALT=change-me-too

# "production" enables Secure cookies; anything else is treated as development.
ENVIRONMENT=development

# ─── CORS / frontend ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Regex of additional allowed origins (defaults to localhost).
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Optional: if set, registration requires this invite code.
REGISTRATION_CODE=

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Supabase Storage (signed contract/invoice PDFs) ──────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=service-role-key
SUPABASE_CONTRACTS_BUCKET=contracts

# ─── Email (Brevo HTTP API) ───────────────────────────────────────────────────
BREVO_API_KEY=
FROM_EMAIL=you@example.com
NOTIFY_EMAIL=you@example.com

# ─── Zoom (demo scheduling, optional) ─────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=me

# ─── GoDaddy domain checker (optional) ────────────────────────────────────────
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ─── Headless Chrome (scraper / PDF, optional overrides) ──────────────────────
CHROME_BIN=
CHROMEDRIVER_BIN=
