VITE_API_URL=http://127.0.0.1:8000
# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# .env is gitignored — .env.example is committed so you know what vars are needed

# Backend API URL
# Local development:
VITE_API_URL=http://127.0.0.1:8000
# Production (uncomment and replace):
# VITE_API_URL=https://your-backend.railway.app


# ── Backend (.env in backend/) ────────────────────────────────────────────────
# These go in backend/.env — NOT this file
# Listed here just so you know what the backend needs

# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres
# SECRET_KEY=your-long-random-secret-key-change-this-in-production
# OPENAI_API_KEY=sk-...                          # optional, for future AI features

# Zoom (optional — only needed for demo scheduling)
# ZOOM_ACCOUNT_ID=...
# ZOOM_CLIENT_ID=...
# ZOOM_CLIENT_SECRET=...
# ZOOM_USER_ID=me                                # or your specific Zoom user ID

# SMTP (optional — needed for invite emails, reminders, contract emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password                # Gmail: use an App Password, not your real password
# FROM_EMAIL=you@gmail.com

# Supabase Storage (optional — only needed for storing signed contract PDFs)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...
# SUPABASE_CONTRACTS_BUCKET=contracts

# Frontend URL (used to build client signing links in contract emails)
# FRONTEND_URL=http://localhost:5173             # local
# FRONTEND_URL=https://your-app.vercel.app       # production